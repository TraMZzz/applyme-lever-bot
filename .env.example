JOOBLE_CAPSOLVER_API_KEY=
JOOBLE_TWOCAPTCHA_API_KEY=
# EXPERIMENTAL falsification test (REPORT §4): set this to route the leverdemo submit through a CaptchaSonic
# out-of-band token instead of the native silent-pass. Needs JOOBLE_PROXY_* (solve-IP must == submit-IP) for
# a fair test. Expected to be siteverify-rejected — set it to prove/disprove, not for production.
JOOBLE_CAPTCHASONIC_API_KEY=
JOOBLE_LLM_API_KEY=
JOOBLE_LLM_MODEL=claude-haiku-4-5-20251001
JOOBLE_IMAP_HOST=imap.gmail.com
JOOBLE_IMAP_USER=
JOOBLE_IMAP_PASSWORD=
JOOBLE_SUBMIT_MODE=dry-run
JOOBLE_HEADFUL=true
JOOBLE_MAX_APPLIES=5
JOOBLE_CHROME_PATH=
# set true if Chrome fails to launch as root / in a container / CI (disables Chrome's sandbox)
JOOBLE_CHROME_NO_SANDBOX=false

# --- Silent-pass tuning (the unattended captcha path — see docs/REPORT.md §4) ---
# Persistent Chrome profile dir (dedicated, NOT your live default profile). Carries the Cloudflare
# __cf_bm/cf_clearance cookies across the 5 applies. Default: ~/.applyme/chrome-profile
JOOBLE_USER_DATA_DIR=
# Coherence: leave locale en-US; set the timezone to match the egress IP's geo if it ever drifts.
JOOBLE_BROWSER_LOCALE=en-US
JOOBLE_BROWSER_TIMEZONE=
# Optional egress-IP reputation pre-flight — IPQualityScore "Proxy Detection API" (free plan; quota shown at
# signup). Endpoint: www.ipqualityscore.com/api/json/ip/<key>/<ip>. Empty = pre-flight skipped (runs anyway).
JOOBLE_IPQS_API_KEY=
# Optional sticky residential/mobile exit (solve-IP must == submit-IP). Empty = direct home IP (preferred
# when it pre-flights clean — a rotating residential pool RAISES the risk score; see §4 "what not to do").
JOOBLE_PROXY_SERVER=
JOOBLE_PROXY_USERNAME=
JOOBLE_PROXY_PASSWORD=
